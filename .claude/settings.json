{
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node_modules/.bin/holdpoint check --staged"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node_modules/.bin/holdpoint check --staged"
          }
        ]
      }
    ]
  }
}

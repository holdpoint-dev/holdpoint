{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30,
        "matcher": "Shell|Read|Write|Grep|Task|MCP:.*"
      }
    ],
    "postToolUse": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "postToolUseFailure": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "afterShellExecution": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "subagentStart": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "subagentStop": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 600,
        "loop_limit": 5
      }
    ],
    "preCompact": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ],
    "stop": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 600,
        "loop_limit": 5
      }
    ],
    "sessionStart": [
      {
        "command": "node .cursor/holdpoint-hook.mjs # HOLDPOINT_MANAGED=cursor",
        "timeout": 30
      }
    ]
  }
}

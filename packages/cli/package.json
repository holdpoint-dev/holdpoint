{
  "name": "@holdpoint/cli",
  "version": "0.1.0-alpha.17",
  "publishConfig": {
    "access": "public"
  },
  "description": "Holdpoint CLI — enforce deterministic eval checkpoints on AI coding agents",
  "homepage": "https://holdpoint.dev",
  "bugs": {
    "url": "https://github.com/holdpoint-dev/holdpoint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdpoint-dev/holdpoint.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "keywords": [
    "holdpoint",
    "ai",
    "agents",
    "claude-code",
    "github-copilot",
    "cursor",
    "eval",
    "checkpoints",
    "ci",
    "yaml"
  ],
  "type": "module",
  "bin": {
    "holdpoint": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@holdpoint/live-daemon": "workspace:*",
    "@holdpoint/live-protocol": "workspace:*",
    "@holdpoint/sdk": "workspace:*",
    "@holdpoint/engine-claude": "workspace:*",
    "@holdpoint/engine-codex": "workspace:*",
    "@holdpoint/engine-copilot": "workspace:*",
    "@holdpoint/engine-cursor": "workspace:*",
    "@holdpoint/types": "workspace:*",
    "@holdpoint/yaml-core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

{
  "name": "@sentinel/engine-claude",
  "version": "0.1.0",
  "private": true,
  "description": "Sentinel engine adapter for Claude Code",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }

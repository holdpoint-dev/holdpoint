{
  "name": "@holdpoint/engine-copilot",
  "version": "0.1.0-alpha.15",
  "publishConfig": {
    "access": "public"
  },
  "description": "Holdpoint engine adapter for GitHub Copilot CLI",
  "homepage": "https://holdpoint.dev",
  "bugs": {
    "url": "https://github.com/holdpoint-dev/holdpoint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdpoint-dev/holdpoint.git",
    "directory": "packages/engine-copilot"
  },
  "license": "MIT",
  "keywords": [
    "holdpoint",
    "ai",
    "agents",
    "claude-code",
    "github-copilot",
    "cursor",
    "eval",
    "checkpoints",
    "ci",
    "yaml"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@holdpoint/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

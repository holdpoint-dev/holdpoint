{
  "name": "@holdpoint/live-daemon",
  "version": "0.1.0-alpha.5",
  "publishConfig": {
    "access": "public"
  },
  "description": "Local singleton daemon for Holdpoint Live ingestion and session state",
  "homepage": "https://holdpoint.dev",
  "bugs": {
    "url": "https://github.com/holdpoint-dev/holdpoint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdpoint-dev/holdpoint.git",
    "directory": "packages/live-daemon"
  },
  "license": "MIT",
  "keywords": [
    "holdpoint",
    "live",
    "daemon",
    "observability",
    "agents"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-live-ui.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts --ignore-pattern 'src/__tests__/**'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@holdpoint/live-protocol": "workspace:*",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@holdpoint/builder": "workspace:*",
    "@holdpoint/live": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

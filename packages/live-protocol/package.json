{
  "name": "@holdpoint/live-protocol",
  "version": "0.1.0-alpha.3",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "description": "Versioned event, HTTP, and WebSocket protocol for Holdpoint Live",
  "homepage": "https://holdpoint.dev",
  "bugs": {
    "url": "https://github.com/holdpoint-dev/holdpoint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdpoint-dev/holdpoint.git",
    "directory": "packages/live-protocol"
  },
  "license": "MIT",
  "keywords": [
    "holdpoint",
    "live",
    "protocol",
    "events",
    "observability",
    "agents"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts --ignore-pattern 'src/__tests__/**'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

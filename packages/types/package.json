{
  "name": "@holdpoint/types",
  "version": "0.1.0-alpha.0",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "description": "Shared TypeScript types for Holdpoint",
  "homepage": "https://holdpoint.dev",
  "bugs": {
    "url": "https://github.com/holdpoint-dev/holdpoint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdpoint-dev/holdpoint.git",
    "directory": "packages/types"
  },
  "license": "MIT",
  "keywords": [
    "holdpoint",
    "ai",
    "agents",
    "claude-code",
    "github-copilot",
    "cursor",
    "eval",
    "checkpoints",
    "ci",
    "yaml"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}

{
  "name": "@holdpoint/yaml-core",
  "version": "0.1.0-alpha.5",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "description": "Shared checks.yaml parser, validator, trigger matcher and runner",
  "homepage": "https://holdpoint.dev",
  "bugs": {
    "url": "https://github.com/holdpoint-dev/holdpoint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdpoint-dev/holdpoint.git",
    "directory": "packages/yaml-core"
  },
  "license": "MIT",
  "keywords": [
    "holdpoint",
    "ai",
    "agents",
    "claude-code",
    "github-copilot",
    "cursor",
    "eval",
    "checkpoints",
    "ci",
    "yaml"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner-entry.d.ts",
      "import": "./dist/runner-entry.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@holdpoint/types": "workspace:*",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

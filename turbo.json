{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.ts", "*.tsx", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "@holdpoint/cli#build": {
      "dependsOn": ["^build", "@holdpoint/builder#build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "*.ts",
        "package.json",
        "tsconfig.json",
        "../../templates/**"
      ],
      "outputs": ["dist/**"]
    },
    "@holdpoint/web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.ts", "*.tsx", ".eslintrc*", "eslint.config.*"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.ts", "*.tsx", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.ts", "*.tsx", "vitest.config.*"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
